# ==============================================================================
# 👁️ IRIS AI - LOCAL DEVELOPMENT ENVIRONMENT CONFIGURATION
# ==============================================================================
# WARNING: NEVER COMMIT YOUR ACTUAL `.env` FILE TO VERSION CONTROL!
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Replace the placeholder strings with your actual API keys.
#
# ARCHITECTURE NOTE: 
# In the compiled production app, users will input their own API keys via the 
# IRIS Settings Dashboard, which encrypts them into the native OS Secure Vault.
# These environment variables are strictly used for local Vite development.
# ==============================================================================

# ------------------------------------------------------------------------------
# [ CORE AI NEURAL UPLINKS ]
# ------------------------------------------------------------------------------

# Primary Google Gemini API Key (Powers the Live Voice/Vision Agent)
VITE_IRIS_AI_API_KEY="your_gemini_api_key_here"

# Standard Google Gemini Key (Powers standard text/fallback generation)
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# Groq API Key (Powers ultra-fast Llama 3 / Mixtral inferencing)
MAIN_VITE_GROQ_API_KEY="your_groq_api_key_here"


# ------------------------------------------------------------------------------
# [ VISION & IMAGE GENERATION ]
# ------------------------------------------------------------------------------

# HuggingFace or Custom Image Generation Keys
VITE_IMAGE_AI_API_KEY="your_image_generation_key_here"

# ------------------------------------------------------------------------------
# [ AUTONOMOUS AGENT TOOLS ]
# ------------------------------------------------------------------------------

# Tavily API Key (Required for the Deep Web Research Agent)
VITE_TAVILY_API_KEY="your_tavily_api_key_here"

# Notion API Integrations (Required for saving AI Research Reports)
VITE_NOTION_API_KEY="your_notion_internal_integration_secret_here"
VITE_NOTION_DATABASE_ID="your_notion_target_database_id_here"


# ------------------------------------------------------------------------------
# [ CLOUD & NETWORK ROUTING ]
# ------------------------------------------------------------------------------

# Supabase Project URL (IRIS-AI cloud auth + profile storage)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase Publishable (anon) Key
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key_here"

# OAuth callback URL configured in Supabase Auth -> URL Configuration
VITE_SUPABASE_REDIRECT_URL="http://127.0.0.1:54321/auth/callback"

# Target URL for the Node.js/Express Auth Backend
VITE_BACKEND_KEY = https://iris-web-two.vercel.app

# Target URL for the Next.js Web Frontend (For Cloud Authentication)
VITE_FRONTEND_KEY = https://irisaiw.vercel.app
